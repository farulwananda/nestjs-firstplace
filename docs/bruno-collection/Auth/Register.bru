meta {
  name: Register
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/auth/register
  body: json
  auth: none
}

body:json {
  {
    "email": "user@example.com",
    "password": "StrongP@ss123",
    "name": "John Doe"
  }
}

script:post-response {
  if (res.status === 201) {
    bru.setVar("accessToken", res.body.data.access_token);
  }
}
